
PORT=8080

# Local MySQL (for development)
# DB_HOST=127.0.0.1
# DB_NAME=defaultdb
# DB_USER=root
# DB_PASS=
# DB_PORT=3306
# DB_SSL=false

# Production Database (Aiven, Railway, etc.)
DB_HOST=your-database-host.com
DB_NAME=your_database_name
DB_USER=your_database_user
DB_PASS=your_database_password
DB_PORT=3306
DB_SSL=true

# Database connection string (use this for deployment)
DATABASE_URL=mysql2://user:password@host:port/database
DATABASE_URI=mysql2://user:password@host:port/database
SERVICE_ID=your-service-id

# ===================================
# OpenRouter API
# ===================================
# Get API key at: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-your-api-key-here
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct
OPENROUTER_TEMPERATURE=0.7
OPENROUTER_MAX_TOKENS=2048

# OpenRouter (check your plan limits at https://openrouter.ai/account)
OPENROUTER_DAILY_LIMIT=333
OPENROUTER_MONTHLY_LIMIT=10000

# JWT key - generate using: openssl rand -base64 32
JWT_KEY=your-jwt-secret-key-here

FRONTEND_URL=http://localhost:3000

# Cloudinary credentials - get from https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Email configuration (optional)
EMAIL_SERVICE=smtp.gmail.com
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_email_password
EMAIL_PORT=587
EMAIL_SECURE=false
